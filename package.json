{
  "name": "godot-mcp",
  "version": "1.0.0",
  "description": "MCP server for integrating Godot game engine with Copilot chat",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "godot-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "scripts/godot_operations.gd",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage tests/*.test.ts",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "godot",
    "copilot",
    "ai",
    "game-development"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
